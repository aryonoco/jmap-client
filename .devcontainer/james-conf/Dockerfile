# Tiny derivative image of apache/james:memory-3.9.0 that bakes in:
#   1. A self-signed PKCS12 keystore for IMAP TLS (without it, James
#      fails at startup because imapserver.xml references a path that
#      does not exist in the upstream image).
#   2. A jmap.properties overlay that sets url.prefix = http://james:80
#      so cross-container JMAP clients on the docker network resolve
#      the session-document apiUrl/downloadUrl/etc. correctly. The
#      upstream default is http://localhost which is a non-starter
#      from any sibling container.
#
# The keystore is generated by .devcontainer/scripts/ensure-james-keystore.sh
# before this image is built. That script is host-arch-agnostic — it
# runs keytool inside a one-shot --platform linux/amd64 container, so
# arm64 hosts (Apple Silicon / Orbstack) and amd64 hosts produce the
# same byte-for-byte PKCS12 keystore.
FROM apache/james:memory-3.9.0
COPY keystore /root/conf/keystore
COPY jmap.properties /root/conf/jmap.properties
