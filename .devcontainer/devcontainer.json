{
  "name": "jmap-client",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "NIM_VERSION": "2.2.8"
    }
  },
  "workspaceFolder": "/workspaces/jmap-client",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/jmap-client,type=bind,consistency=cached",

  "containerUser": "vscode",
  "remoteUser": "vscode",

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": false,
      "configureZshAsDefaultShell": true,
      "username": "vscode",
      "userUid": "1000",
      "userGid": "1000",
      "upgradePackages": true
    },
    "ghcr.io/devcontainers-extra/features/mise:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },

  "mounts": [
    {
      "source": "jmc-nimble-cache-${devcontainerId}",
      "target": "/home/vscode/.nimble",
      "type": "volume"
    },
    {
      "source": "jmc-gh-config-${devcontainerId}",
      "target": "/home/vscode/.config/gh",
      "type": "volume"
    },
    {
      "source": "jmc-mise-data-${devcontainerId}",
      "target": "/home/vscode/.local/share/mise",
      "type": "volume"
    },
    {
      "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.ssh",
      "target": "/home/vscode/.ssh",
      "type": "bind"
    }
  ],

  "containerEnv": {
    "MISE_DATA_DIR": "/home/vscode/.local/share/mise",
    "MISE_STATE_DIR": "/home/vscode/.local/share/mise/state",
    "MISE_TRUSTED_CONFIG_PATHS": "/workspaces",
    "MISE_YES": "1",
    "DO_NOT_TRACK": "1",
    "TZ": "UTC",
    "USE_BUILTIN_RIPGREP": "0",
    "GIT_PAGER": "delta",
    "EDITOR": "nano",
    "VISUAL": "nano"
  },

  "runArgs": [
    "--init",
    "--name", "jmap-client",
    "--hostname", "jmap-client",
    "--cap-drop=ALL",
    "--cap-add=NET_BIND_SERVICE",
    "--cap-add=DAC_OVERRIDE",
    "--cap-add=SYS_ADMIN",
    "--security-opt=no-new-privileges:true"
  ],

  "onCreateCommand": "bash .devcontainer/scripts/on-create.sh",
  "postCreateCommand": "bash .devcontainer/scripts/post-create.sh",
  "postStartCommand": "bash .devcontainer/scripts/post-start.sh",
  "waitFor": "onCreateCommand",
  "shutdownAction": "stopContainer",

  "customizations": {
    "vscode": {
      "extensions": [
        "NimLang.nimlang",
        "arnetheduck.vscode-nph",
        "vadimcn.vscode-lldb",

        "eamodio.gitlens",
        "mhutchie.git-graph",
        "usernamehw.errorlens",
        "streetsidesoftware.code-spell-checker",
        "github.vscode-github-actions",

        "EditorConfig.EditorConfig",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml",
        "nefrob.vscode-just-syntax",
        "hverlin.mise-vscode",
        "oderwat.indent-rainbow"
      ],
      "settings": {
        "nim.provider": "lsp",
        "nim.lintOnSave": true,
        "nim.buildOnSave": false,
        "nim.buildCommand": "c",
        "nim.project": ["src/jmap_client.nim"],
        "nim.test-project": "tests/test_all.nim",
        "nim.lsp.path": "/home/vscode/.local/share/mise/shims/nimlangserver",
        "nim.nimsuggestPath": "/home/vscode/nim/bin/nimsuggest",
        "nim.useNimCheck": true,
        "nim.maxNimsuggestProcesses": 1,
        "nim.nimsuggestIdleTimeout": 20000,
        "nim.timeout": 120000,
        "nim.autoRestart": true,
        "nim.projectMapping": [
          {
            "projectFile": "tests/test_all.nim",
            "fileRegex": "tests/.*\\.nim"
          },
          {
            "projectFile": "src/jmap_client.nim",
            "fileRegex": ".*\\.nim"
          }
        ],
        "nim.notificationVerbosity": "warning",
        "nimlangserver.trace.server": "off",

        "nph.formatOnSave": true,

        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": { "path": "/bin/zsh", "args": ["-l"] },
          "bash": { "path": "/bin/bash" }
        },

        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.rulers": [80, 120],
        "editor.bracketPairColorization.enabled": true,
        "editor.guides.bracketPairs": "active",

        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": true,
        "files.exclude": {
          "**/nimcache": true,
          "**/.nimble": true,
          "**/bin": true
        },
        "files.associations": {
          "*.nim": "nim",
          "*.nims": "nim",
          "*.nimble": "nim"
        },

        "[nim]": {
          "editor.tabSize": 2,
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "arnetheduck.vscode-nph"
        },
        "[toml]": {
          "editor.defaultFormatter": "tamasfe.even-better-toml",
          "editor.formatOnSave": true
        },
        "[markdown]": {
          "editor.wordWrap": "on"
        },
        "[json]": {
          "editor.tabSize": 2
        },
        "[yaml]": {
          "editor.tabSize": 2
        },

        "errorLens.enabledDiagnosticLevels": ["error", "warning"],

        "cSpell.language": "en-GB",
        "cSpell.dictionaries": [
          "softwareTerms",
          "networking-terms",
          "computing-acronyms",
          "coding-compound-terms",
          "software-tools",
          "web-services",
          "bash",
          "shellscript",
          "docker",
          "git",
          "cpp",
          "makefile",
          "filetypes",
          "public-licenses",
          "fullstack"
        ],
        "cSpell.enabledFileTypes": {
          "nim": true,
          "markdown": true,
          "yaml": true,
          "json": true,
          "shellscript": true,
          "toml": true
        },
        "cSpell.customDictionaries": {
          "project-words": {
            "name": "project-words",
            "path": "${workspaceFolder}/project-words.txt",
            "addWords": true,
            "scope": "workspace"
          }
        }
      }
    }
  },

  "hostRequirements": {
    "cpus": 2,
    "memory": "4gb",
    "storage": "16gb"
  }
}
