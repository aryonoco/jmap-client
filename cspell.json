{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en-GB",
  "dictionaries": [
    "en-gb",
    "softwareTerms",
    "networking-terms",
    "computing-acronyms",
    "coding-compound-terms",
    "software-tools",
    "web-services",
    "bash",
    "shellscript",
    "docker",
    "git",
    "cpp",
    "makefile",
    "filetypes",
    "public-licenses",
    "fullstack",
    "project-words"
  ],
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": "./project-words.txt",
      "addWords": true
    }
  ],
  "ignorePaths": [
    "nimcache/**",
    "nimblecache/**",
    "nimbledeps/**",
    "bin/**",
    "build/**",
    "htmldocs/**",
    "*.lock",
    ".git/**",
    ".devcontainer/config/p10k.zsh",
    "docs/rfcs/**",
    "LICENSES/**"
  ],
  "ignoreRegExpList": [
    "/[a-f0-9]{32,}/gi",
    "/0x[a-f0-9]+/gi"
  ]
}
